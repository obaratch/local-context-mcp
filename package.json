{
	"name": "local-context-mcp",
	"version": "2.0.0",
	"description": "Local Context MCP server for sharing current local context with AI and users",
	"author": "Obalab",
	"private": true,
	"license": "MIT",
	"engines": {
		"node": ">=24"
	},
	"packageManager": "npm@11",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"dev": "tsx watch src/index.ts",
		"security:scan": "./scripts/security-scan.sh",
		"docker:build": "docker build -t obaratch/local-context-mcp-server .",
		"test": "run-s test:unit test:integration",
		"test:unit": "vitest run tests/tools",
		"test:integration": "run-s build test:integration:run",
		"test:integration:run": "vitest run tests/integration",
		"format": "biome format --write .",
		"lint": "run-s lint:biome lint:oxlint",
		"lint:biome": "biome check .",
		"lint:oxlint": "oxlint ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@types/node": "^24.6.1",
		"npm-run-all": "^4.1.5",
		"oxlint": "^1.56.0",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.27.1",
		"conf": "^15.1.0",
		"date-fns": "^4.1.0",
		"zod": "^4.3.6"
	}
}
